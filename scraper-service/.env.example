PORT=3001

# BrightData Residential Proxy
# Get these from BrightData > Proxies > Your Zone > Access parameters
BRIGHTDATA_CUSTOMER_ID=your_customer_id
BRIGHTDATA_ZONE=residential_proxy1
BRIGHTDATA_PASSWORD=your_zone_password

# Shared secret — Vercel sends this in X-Scraper-Secret header
# Generate: openssl rand -hex 32
SCRAPER_SECRET=your_random_secret_here
