PORT=3001

# ── BrightData Scraping Browser ────────────────────────────────
# Get from: BrightData dashboard → Scraping Browser → your zone → Access parameters
# Format: wss://brd-customer-XXXX:PASSWORD@brd.superproxy.io:9222
BRIGHTDATA_BROWSER_WS=wss://brd-customer-XXXX:PASSWORD@brd.superproxy.io:9222

# ── Auth ──────────────────────────────────────────────────────
# Shared secret — Vercel sends this in X-Scraper-Secret header
# Generate with: openssl rand -hex 32
SCRAPER_SECRET=your_random_secret_here
