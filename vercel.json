{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://voxrate.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,X-Requested-With,X-Cron-Secret,x-cron-ts" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/monitor",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sentiment-digest",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/expire-trials",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/onboarding-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/account-health",
      "schedule": "0 */6 * * *"
    }
  ]
}
